{
  "manifest_version": 3,
  "name": "VOD Recovery Extension",
  "version": "1.0",
  "permissions": ["scripting", "activeTab"],
  "host_permissions": [
    "*://streamscharts.com/*",
    "*://usher.ttvnw.net/*",
    "*://*.twitch.tv/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  }
}