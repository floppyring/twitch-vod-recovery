{
  "manifest_version": 3,
  "name": "Twitch VOD Recovery Extension",
  "version": "1.0",
  "permissions": [
    "scripting",
    "activeTab"
  ],
  "host_permissions": [
    "https://*.cloudfront.net/*",
    "https://*.twitch.tv/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  }
}