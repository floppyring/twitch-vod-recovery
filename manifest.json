{
  "manifest_version": 3,
  "name": "Twitch VOD Recovery Extension",
  "version": "1.0",
  "permissions": [
    "scripting",
    "activeTab",
    "declarativeNetRequest"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "ruleset_1",
        "enabled": true,
        "path": "rules.json"
      }
    ]
  }
}